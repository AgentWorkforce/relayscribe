# Relayscribe — environment configuration
# Copy to .env and fill in values. NEVER commit .env.

# URL of the Relay transcription worker (no trailing slash)
WORKER_URL=https://<your-worker>.workers.dev

# Shared recorder token matching the cloud worker's RecorderTranscribeToken secret
RECORDER_TRANSCRIBE_TOKEN=

# Recall.ai region base URL (default: us-west-2)
RECALL_API_URL=https://us-west-2.recall.ai

# Transcript ingest endpoint used after Brainstorm mic transcription
TRANSCRIPTS_INGEST_URL=https://agentrelay.com/cloud/api/v1/webhooks/transcripts
